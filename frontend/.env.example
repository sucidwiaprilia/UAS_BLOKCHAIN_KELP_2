# ========================================================
# EDU PAY CHAIN - FRONTEND ENVIRONMENT CONFIGURATION
# ========================================================
# INSTRUKSI:
# 1. Salin file ini menjadi ".env" (cp .env.example .env)
# 2. Isi variabel di bawah ini sesuai dengan environment Anda
# 3. JANGAN PERNAH meng-upload file ".env" asli Anda ke GitHub!

# Alamat Smart Contract EduPayChain yang sudah di-deploy ke Sepolia Testnet
VITE_CONTRACT_ADDRESS=0x83CE915430fE4B1114f766B769B47b4dF1dA8C67

# Chain ID Sepolia (11155111)
VITE_CHAIN_ID=11155111

# Gateway IPFS Publik (Protocol Labs Dweb Gateway)
VITE_IPFS_GATEWAY=https://dweb.link/ipfs

# [Opsional] Jika Anda menggunakan layanan Pinata IPFS Pinning SDK di masa depan
# VITE_PINATA_API_KEY=your_pinata_api_key_here
# VITE_PINATA_SECRET_KEY=your_pinata_secret_key_here
